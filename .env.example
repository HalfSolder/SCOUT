# Copy this file to .env and fill in real values. .env is gitignored.

# xAI API key for Grok. Get one at https://console.x.ai.
XAI_API_KEY=xai-...

# "dry" = simulated sensors/actuators (use on a laptop while parts arrive)
# "real" = drive real GPIO via the Pi
HARDWARE=dry

# Notification target when a safety limit trips (optional).
# ntfy.sh topic. Leave blank to disable.
NTFY_TOPIC=

# Optional: separate topic for urgent alerts so quiet messages do not
# vibrate a phone at 4 am.
NTFY_TOPIC_URGENT=
