# Copy this file to .env and fill in real values. .env is gitignored.

# OpenAI API key for GPT-5.5
OPENAI_API_KEY=sk-...

# "dry" = simulated sensors/actuators (use on a laptop while parts arrive)
# "real" = drive real GPIO via the Pi
HARDWARE=dry

# Notification target when a safety limit trips (optional)
# ntfy.sh topic. Leave blank to disable.
NTFY_TOPIC=
